<Window x:Class="Johann.UI.Views.SettingsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Einstellungen – Platé.Johann"
        Height="680" Width="820"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <Style x:Key="HintStyle" TargetType="TextBlock">
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="Foreground"   Value="#888"/>
            <Setter Property="Margin"       Value="0,0,0,6"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Margin"     Value="0,8,0,2"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="FieldBox" TargetType="TextBox">
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="Padding"    Value="6,4"/>
            <Setter Property="BorderBrush"      Value="#CCC"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Margin"     Value="0,0,0,4"/>
        </Style>
        <Style x:Key="PromptBox" TargetType="TextBox">
            <Setter Property="FontFamily"              Value="Consolas, Courier New"/>
            <Setter Property="FontSize"                Value="12"/>
            <Setter Property="AcceptsReturn"           Value="True"/>
            <Setter Property="TextWrapping"            Value="Wrap"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="BorderBrush"             Value="#CCC"/>
            <Setter Property="BorderThickness"         Value="1"/>
            <Setter Property="Padding"                 Value="6"/>
            <Setter Property="SpellCheck.IsEnabled"    Value="False"/>
        </Style>
        <Style x:Key="BrowseButton" TargetType="Button">
            <Setter Property="Padding"    Value="10,4"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Margin"     Value="6,0,0,0"/>
            <Setter Property="MinWidth"   Value="80"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0">

            <!-- ── Allgemein (Name, Firma) ─────────────────────────────────── -->
            <TabItem Header="Allgemein">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="12,10,12,8">
                    <StackPanel>
                        <TextBlock Style="{StaticResource HintStyle}"
                                   Text="Benutzerdaten – werden in PDF-Kopf und -Fuß eingedruckt."/>

                        <TextBlock Style="{StaticResource LabelStyle}" Text="Name"/>
                        <TextBox   Style="{StaticResource FieldBox}"
                                   Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Style="{StaticResource LabelStyle}" Text="Firma"/>
                        <TextBox   Style="{StaticResource FieldBox}"
                                   Text="{Binding Firma, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ── Verzeichnisse ───────────────────────────────────────────── -->
            <TabItem Header="Verzeichnisse">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="12,10,12,8">
                    <StackPanel>
                        <TextBlock Style="{StaticResource HintStyle}"
                                   Text="Verzeichnispfade können direkt eingegeben oder per Ordner-Browser ausgewählt werden."/>

                        <TextBlock Style="{StaticResource LabelStyle}" Text="Quellverzeichnis (MP3-Eingang)"/>
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Style="{StaticResource BrowseButton}"
                                    Content="Durchsuchen…"
                                    Command="{Binding BrowseQuellCommand}"/>
                            <TextBox Style="{StaticResource FieldBox}"
                                     Text="{Binding Quellverzeichnis, UpdateSourceTrigger=PropertyChanged}"/>
                        </DockPanel>

                        <TextBlock Style="{StaticResource LabelStyle}" Text="Archivverzeichnis (verarbeitete MP3s)"/>
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Style="{StaticResource BrowseButton}"
                                    Content="Durchsuchen…"
                                    Command="{Binding BrowseArchivCommand}"/>
                            <TextBox Style="{StaticResource FieldBox}"
                                     Text="{Binding Archivverzeichnis, UpdateSourceTrigger=PropertyChanged}"/>
                        </DockPanel>

                        <TextBlock Style="{StaticResource LabelStyle}" Text="Ausgabeverzeichnis (JSON, PDF, HTML)"/>
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Style="{StaticResource BrowseButton}"
                                    Content="Durchsuchen…"
                                    Command="{Binding BrowseAusgabeCommand}"/>
                            <TextBox Style="{StaticResource FieldBox}"
                                     Text="{Binding Ausgabeverzeichnis, UpdateSourceTrigger=PropertyChanged}"/>
                        </DockPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ── System-Nachricht ────────────────────────────────────────── -->
            <TabItem Header="System-Nachricht">
                <Grid Margin="12,10,12,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Style="{StaticResource HintStyle}"
                               Text="Globale Rolle/Persönlichkeit für alle GPT-Aufrufe (system message)."/>
                    <TextBox Grid.Row="1" Style="{StaticResource PromptBox}"
                             Text="{Binding SystemMessage, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>
            </TabItem>

            <!-- ── Abstract ────────────────────────────────────────────────── -->
            <TabItem Header="Abstract">
                <Grid Margin="12,10,12,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Style="{StaticResource HintStyle}"
                               Text="Prompt für die Kurzfassung. Platzhalter: {word_limit}, {transcript}"/>
                    <TextBox Grid.Row="1" Style="{StaticResource PromptBox}"
                             Text="{Binding AbstractPrompt, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>
            </TabItem>

            <!-- ── Strukturiert ─────────────────────────────────────────────── -->
            <TabItem Header="Strukturiert">
                <Grid Margin="12,10,12,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Style="{StaticResource HintStyle}"
                               Text="Prompt für die strukturierte Zusammenfassung. Platzhalter: {word_limit}, {transcript}"/>
                    <TextBox Grid.Row="1" Style="{StaticResource PromptBox}"
                             Text="{Binding StructuredPrompt, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>
            </TabItem>

            <!-- ── Fließtext ───────────────────────────────────────────────── -->
            <TabItem Header="Fließtext">
                <Grid Margin="12,10,12,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Style="{StaticResource HintStyle}"
                               Text="Prompt für die Fließtext-Zusammenfassung. Platzhalter: {transcript}"/>
                    <TextBox Grid.Row="1" Style="{StaticResource PromptBox}"
                             Text="{Binding ProsePrompt, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>
            </TabItem>

            <!-- ── E-Mail ──────────────────────────────────────────────────── -->
            <TabItem Header="E-Mail">
                <Grid Margin="12,10,12,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Style="{StaticResource HintStyle}"
                               Text="Prompt für die E-Mail-Generierung. Platzhalter: {prose_summary}"/>
                    <TextBox Grid.Row="1" Style="{StaticResource PromptBox}"
                             Text="{Binding EmailPrompt, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>
            </TabItem>

            <!-- ── Aufgabe ─────────────────────────────────────────────────── -->
            <TabItem Header="Aufgabe">
                <Grid Margin="12,10,12,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Style="{StaticResource HintStyle}"
                               Text="Prompt für Aufgaben-Einträge. Platzhalter: {transcript}"/>
                    <TextBox Grid.Row="1" Style="{StaticResource PromptBox}"
                             Text="{Binding AufgabePrompt, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>
            </TabItem>

            <!-- ── Gesprächsnotiz ──────────────────────────────────────────── -->
            <TabItem Header="Gesprächsnotiz">
                <Grid Margin="12,10,12,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Style="{StaticResource HintStyle}"
                               Text="Prompt für Gesprächsnotiz-Einträge. Platzhalter: {transcript}"/>
                    <TextBox Grid.Row="1" Style="{StaticResource PromptBox}"
                             Text="{Binding GespraechsnotizPrompt, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>
            </TabItem>

            <!-- ── Stundenzettel ───────────────────────────────────────────── -->
            <TabItem Header="Stundenzettel">
                <Grid Margin="12,10,12,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Style="{StaticResource HintStyle}"
                               Text="Prompt für Stundenzettel-Einträge. Platzhalter: {transcript}"/>
                    <TextBox Grid.Row="1" Style="{StaticResource PromptBox}"
                             Text="{Binding StundenzettelPrompt, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>
            </TabItem>

            <!-- ── Analog ─────────────────────────────────────────────────── -->
            <TabItem Header="Analog">
                <Grid Margin="12,10,12,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Style="{StaticResource HintStyle}"
                               Text="Prompt für analoge Einträge. Platzhalter: {transcript}"/>
                    <TextBox Grid.Row="1" Style="{StaticResource PromptBox}"
                             Text="{Binding AnalogPrompt, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- Bottom bar: status + action buttons -->
        <DockPanel Grid.Row="1" Margin="0,12,0,0" LastChildFill="False">
            <TextBlock DockPanel.Dock="Left"
                       Text="{Binding StatusMessage}"
                       Foreground="#27AE60" FontSize="12"
                       VerticalAlignment="Center"/>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="Standard wiederherstellen"
                        Command="{Binding ResetCommand}"
                        Padding="12,6" Margin="0,0,8,0" FontSize="13"/>
                <Button Content="Speichern"
                        Command="{Binding SaveCommand}"
                        Padding="14,6" FontSize="13"
                        Background="#E63123" Foreground="White"
                        BorderThickness="0"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
