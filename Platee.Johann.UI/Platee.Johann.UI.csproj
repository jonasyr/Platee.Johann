  </ItemGroup>

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <ApplicationIcon>..\Johann.ico</ApplicationIcon>
    <Version>1.1.0</Version>
    <StartupObject>Platee.Johann.UI.Program</StartupObject>
  </PropertyGroup>

  <ItemGroup>
    <Resource Include="..\Johann.ico" Link="Johann.ico" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Assets\RELEASE_NOTES.md" />
  </ItemGroup>

</Project>
