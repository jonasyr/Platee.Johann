<Project Sdk="Microsoft.NET.Sdk">

  <ItemGroup>
    <ProjectReference Include="..\Platee.Johann.Domain\Platee.Johann.Domain.csproj" />
    <ProjectReference Include="..\Platee.Johann.Application\Platee.Johann.Application.csproj" />
    <ProjectReference Include="..\Platee.Johann.Infrastructure\Platee.Johann.Infrastructure.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.0" />
