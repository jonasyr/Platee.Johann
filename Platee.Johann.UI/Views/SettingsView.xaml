<Window x:Class="Platee.Johann.UI.Views.SettingsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Einstellungen – Platé.Johann"
        Height="680" Width="820"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <Style x:Key="HintStyle" TargetType="TextBlock">
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="Foreground"   Value="#888"/>
            <Setter Property="Margin"       Value="0,0,0,6"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Margin"     Value="0,8,0,2"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="FieldBox" TargetType="TextBox">
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="Padding"    Value="6,4"/>
            <Setter Property="BorderBrush"      Value="#CCC"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Margin"     Value="0,0,0,4"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
        <Style x:Key="PromptBox" TargetType="TextBox">
            <Setter Property="FontFamily"              Value="Consolas, Courier New"/>
            <Setter Property="FontSize"                Value="12"/>
            <Setter Property="AcceptsReturn"           Value="True"/>
            <Setter Property="TextWrapping"            Value="Wrap"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="BorderBrush"             Value="#CCC"/>
            <Setter Property="BorderThickness"         Value="1"/>
            <Setter Property="Padding"                 Value="6"/>
            <Setter Property="SpellCheck.IsEnabled"    Value="False"/>
            <Setter Property="HorizontalAlignment"     Value="Stretch"/>
        </Style>
        <Style x:Key="BrowseButton" TargetType="Button">
            <Setter Property="Padding"    Value="10,4"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Margin"     Value="6,0,0,0"/>
            <Setter Property="MinWidth"   Value="80"/>
        </Style>

        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <CollectionViewSource x:Key="GroupedSections" Source="{Binding Sections}">
            <CollectionViewSource.GroupDescriptions>
                <PropertyGroupDescription PropertyName="Group"/>
            </CollectionViewSource.GroupDescriptions>
        </CollectionViewSource>

        <Style x:Key="SectionNavItemStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="6,2"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#F2F2F2"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#E63123"/>
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#C92D21"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    BorderBrush="#DADADA"
                    BorderThickness="1"
                    Background="#FAFAFA">
                <DockPanel LastChildFill="True">
                    <ListBox ItemsSource="{Binding Source={StaticResource GroupedSections}}"
                             SelectedItem="{Binding SelectedSection, Mode=TwoWay}"
                             BorderThickness="0"
                             Background="Transparent"
                             ItemContainerStyle="{StaticResource SectionNavItemStyle}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             Margin="0,0,0,8">
                        <ListBox.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}"
                                                   Margin="10,14,10,4"
                                                   FontSize="10"
                                                   FontWeight="Bold"
                                                   Foreground="#666"/>
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </ListBox.GroupStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Label}"
                                           TextTrimming="CharacterEllipsis"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Border Grid.Column="2"
                    BorderBrush="#DADADA"
                    BorderThickness="1">
                <Grid>
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto"
                                  Margin="12,10,12,8"
                                  Visibility="{Binding IsGeneralSelected, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource HintStyle}"
                                       Text="Benutzerdaten – werden in PDF-Kopf und -Fuß eingedruckt."/>

                            <TextBlock Style="{StaticResource LabelStyle}" Text="Name"/>
                            <TextBox Style="{StaticResource FieldBox}"
                                     Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Style="{StaticResource LabelStyle}" Text="Firma"/>
                            <TextBox Style="{StaticResource FieldBox}"
                                     Text="{Binding Firma, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </ScrollViewer>

                    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto"
                                  Margin="12,10,12,8"
                                  Visibility="{Binding IsPathsSelected, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource HintStyle}"
                                       Text="Verzeichnispfade können direkt eingegeben oder per Ordner-Browser ausgewählt werden."/>
                            <TextBlock Style="{StaticResource HintStyle}"
                                       Foreground="#C67C00"
                                       Visibility="{Binding HasPathStatusMessage, Converter={StaticResource BoolToVisibility}}"
                                       Text="{Binding PathStatusMessage}"/>

                            <TextBlock Style="{StaticResource LabelStyle}" Text="Quellverzeichnis (MP3-Eingang)"/>
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Style="{StaticResource BrowseButton}"
                                        Content="Durchsuchen…"
                                        Command="{Binding BrowseQuellCommand}"/>
                                <TextBox Style="{StaticResource FieldBox}"
                                         Text="{Binding Quellverzeichnis, UpdateSourceTrigger=PropertyChanged}"/>
                            </DockPanel>

                            <TextBlock Style="{StaticResource LabelStyle}" Text="Archivverzeichnis (verarbeitete MP3s)"/>
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Style="{StaticResource BrowseButton}"
                                        Content="Durchsuchen…"
                                        Command="{Binding BrowseArchivCommand}"/>
                                <TextBox Style="{StaticResource FieldBox}"
                                         Text="{Binding Archivverzeichnis, UpdateSourceTrigger=PropertyChanged}"/>
                            </DockPanel>

                            <TextBlock Style="{StaticResource LabelStyle}" Text="Ausgabeverzeichnis (JSON, PDF, HTML)"/>
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Style="{StaticResource BrowseButton}"
                                        Content="Durchsuchen…"
                                        Command="{Binding BrowseAusgabeCommand}"/>
                                <TextBox Style="{StaticResource FieldBox}"
                                         Text="{Binding Ausgabeverzeichnis, UpdateSourceTrigger=PropertyChanged}"/>
                            </DockPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto"
                                  Margin="12,10,12,8"
                                  Visibility="{Binding IsTeamSelected, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource HintStyle}"
                                       Text="Pfad zur gemeinsamen Prompt-Datei auf dem Netzlaufwerk. Standard: Z:\12_Tools\Peano\Johann\prompts.json. Wenn erreichbar, werden diese Prompts anstelle der lokalen verwendet."/>

                            <TextBlock Style="{StaticResource LabelStyle}" Text="Globale Prompt-Datei"/>
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Style="{StaticResource BrowseButton}"
                                        Content="Durchsuchen&#x2026;"
                                        Command="{Binding BrowseGlobalPromptFileCommand}"/>
                                <TextBox Style="{StaticResource FieldBox}"
                                         Text="{Binding GlobalPromptFilePath, UpdateSourceTrigger=PropertyChanged}"/>
                            </DockPanel>

                            <TextBlock Style="{StaticResource HintStyle}" Margin="0,8,0,0"
                                       Text="{Binding GlobalPromptStatus}"/>
                        </StackPanel>
                    </ScrollViewer>

                    <Grid Margin="12,10,12,8"
                          Visibility="{Binding IsSystemMessageSelected, Converter={StaticResource BoolToVisibility}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Style="{StaticResource HintStyle}"
                                   Text="Globale Rolle/Persönlichkeit für alle GPT-Aufrufe (system message)."/>
                        <TextBox Grid.Row="1" Style="{StaticResource PromptBox}"
                                 Text="{Binding SystemMessage, UpdateSourceTrigger=LostFocus}"/>
                    </Grid>

                    <Grid Margin="12,10,12,8"
                          Visibility="{Binding IsAbstractSelected, Converter={StaticResource BoolToVisibility}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Style="{StaticResource HintStyle}"
                                   Text="Prompt für die Kurzfassung. Platzhalter: {word_limit}, {transcript}"/>
                        <TextBox Grid.Row="1" Style="{StaticResource PromptBox}"
                                 Text="{Binding AbstractPrompt, UpdateSourceTrigger=LostFocus}"/>
                    </Grid>

                    <Grid Margin="12,10,12,8"
                          Visibility="{Binding IsStructuredSelected, Converter={StaticResource BoolToVisibility}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Style="{StaticResource HintStyle}"
                                   Text="Prompt für die strukturierte Zusammenfassung. Platzhalter: {word_limit}, {transcript}"/>
                        <TextBox Grid.Row="1" Style="{StaticResource PromptBox}"
                                 Text="{Binding StructuredPrompt, UpdateSourceTrigger=LostFocus}"/>
                    </Grid>

                    <Grid Margin="12,10,12,8"
                          Visibility="{Binding IsProseSelected, Converter={StaticResource BoolToVisibility}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Style="{StaticResource HintStyle}"
                                   Text="Prompt für die Fließtext-Zusammenfassung. Platzhalter: {transcript}"/>
                        <TextBox Grid.Row="1" Style="{StaticResource PromptBox}"
                                 Text="{Binding ProsePrompt, UpdateSourceTrigger=LostFocus}"/>
                    </Grid>

                    <Grid Margin="12,10,12,8"
                          Visibility="{Binding IsEmailSelected, Converter={StaticResource BoolToVisibility}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Style="{StaticResource HintStyle}"
                                   Text="Prompt für die E-Mail-Generierung. Platzhalter: {prose_summary}"/>
                        <TextBox Grid.Row="1" Style="{StaticResource PromptBox}"
                                 Text="{Binding EmailPrompt, UpdateSourceTrigger=LostFocus}"/>
                    </Grid>

                    <Grid Margin="12,10,12,8"
                          Visibility="{Binding IsAufgabeSelected, Converter={StaticResource BoolToVisibility}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Style="{StaticResource HintStyle}"
                                   Text="Prompt für Aufgaben-Einträge. Platzhalter: {transcript}"/>
                        <TextBox Grid.Row="1" Style="{StaticResource PromptBox}"
                                 Text="{Binding AufgabePrompt, UpdateSourceTrigger=LostFocus}"/>
                    </Grid>

                    <Grid Margin="12,10,12,8"
                          Visibility="{Binding IsGespraechsnotizSelected, Converter={StaticResource BoolToVisibility}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Style="{StaticResource HintStyle}"
                                   Text="Prompt für Gesprächsnotiz-Einträge. Platzhalter: {transcript}"/>
                        <TextBox Grid.Row="1" Style="{StaticResource PromptBox}"
                                 Text="{Binding GespraechsnotizPrompt, UpdateSourceTrigger=LostFocus}"/>
                    </Grid>

                    <Grid Margin="12,10,12,8"
                          Visibility="{Binding IsStundenzettelSelected, Converter={StaticResource BoolToVisibility}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Style="{StaticResource HintStyle}"
                                   Text="Prompt für Stundenzettel-Einträge. Platzhalter: {transcript}"/>
                        <TextBox Grid.Row="1" Style="{StaticResource PromptBox}"
                                 Text="{Binding StundenzettelPrompt, UpdateSourceTrigger=LostFocus}"/>
                    </Grid>

                    <Grid Margin="12,10,12,8"
                          Visibility="{Binding IsAnalogSelected, Converter={StaticResource BoolToVisibility}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Style="{StaticResource HintStyle}"
                                   Text="Prompt für analoge Einträge. Platzhalter: {transcript}"/>
                        <TextBox Grid.Row="1" Style="{StaticResource PromptBox}"
                                 Text="{Binding AnalogPrompt, UpdateSourceTrigger=LostFocus}"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- Bottom bar: status + action buttons -->
        <DockPanel Grid.Row="1" Margin="0,12,0,0" LastChildFill="False">
            <TextBlock DockPanel.Dock="Left"
                       Text="{Binding StatusMessage}"
                       Foreground="#27AE60" FontSize="12"
                       VerticalAlignment="Center"/>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="Standard wiederherstellen"
                        Command="{Binding ResetCommand}"
                        Padding="12,6" Margin="0,0,8,0" FontSize="13"/>
                <Button Content="Speichern"
                        Command="{Binding SaveCommand}"
                        Padding="14,6" FontSize="13"
                        Background="#E63123" Foreground="White"
                        BorderThickness="0"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>

