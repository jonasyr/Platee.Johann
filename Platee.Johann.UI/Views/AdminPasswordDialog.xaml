<Window x:Class="Platee.Johann.UI.Views.AdminPasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Admin-Zugang"
        Height="180" Width="360"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="NoResize">
    <StackPanel Margin="20">
        <TextBlock Text="Admin-Passwort eingeben:" FontSize="13" Margin="0,0,0,8"/>
        <PasswordBox x:Name="PasswordInput" FontSize="13" Padding="6,4" Margin="0,0,0,16"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Abbrechen" Padding="12,6" Margin="0,0,8,0" IsCancel="True"
                    Click="Cancel_Click"/>
            <Button Content="Anmelden" Padding="12,6" IsDefault="True"
                    Background="#E63123" Foreground="White" BorderThickness="0"
                    Click="Login_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
