<Window x:Class="Platee.Johann.UI.Views.ProcessDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Verarbeitungs-Log – Platé.Johann"
        Height="400" Width="620"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <DockPanel Margin="12">
        <!-- Buttons at bottom -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Erledigte löschen" Padding="10,5" Margin="0,0,6,0"
                    Cursor="Hand" Click="RemoveCompleted_Click"/>
            <Button Content="Alle löschen" Padding="10,5" Margin="0,0,6,0"
                    Cursor="Hand" Click="ClearAll_Click"/>
            <Button Content="Schließen" Padding="10,5" IsDefault="True"
                    Cursor="Hand" Click="Close_Click"/>
        </StackPanel>

        <!-- Log list -->
        <ListBox ItemsSource="{Binding}"
                 BorderThickness="1" BorderBrush="#E0E0E0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="4,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding DisplayTime}"
                                   FontSize="11" Foreground="#888" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding Message}"
                                   FontSize="12" TextWrapping="Wrap" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="2" Orientation="Horizontal"
                                    HorizontalAlignment="Right" VerticalAlignment="Center">
                            <!-- Spinner when running -->
                            <ProgressBar IsIndeterminate="True" Width="40" Height="4"
                                         Foreground="#E63123" Margin="0,0,4,0"
                                         Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}"/>
                            <TextBlock Text="{Binding ResultMessage}" FontSize="11"
                                       Foreground="#555" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</Window>
