<UserControl x:Class="Platee.Johann.UI.Views.ToastView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Platee.Johann.UI.ViewModels"
             xmlns:conv="clr-namespace:Platee.Johann.UI.Converters"
             MouseEnter="OnMouseEnter"
             MouseLeave="OnMouseLeave">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:NullToVisibilityConverter x:Key="NullToVis"/>
        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="4,0,0,0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#555555"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="DetailsLinkStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#E63123"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="TextBlock.TextDecorations" Value="Underline"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Border Background="White"
            BorderBrush="#DDDDDD"
            BorderThickness="1"
            CornerRadius="6"
            Margin="0,0,0,6"
            MinWidth="260"
            MaxWidth="340">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.15"/>
        </Border.Effect>
        <Grid>
            <!-- Left tone accent stripe -->
            <Rectangle Width="5" HorizontalAlignment="Left">
                <Rectangle.Style>
                    <Style TargetType="Rectangle">
                        <Setter Property="Fill" Value="#27AE60"/>
                        <Setter Property="RadiusX" Value="5"/>
                        <Setter Property="RadiusY" Value="5"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Tone}" Value="Warn">
                                <Setter Property="Fill" Value="#B76E00"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Tone}" Value="Error">
                                <Setter Property="Fill" Value="#E63123"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Rectangle.Style>
            </Rectangle>

            <!-- Content area -->
            <DockPanel Margin="14,8,8,8">
                <!-- Close button -->
                <Button DockPanel.Dock="Right"
                        Content="×"
                        Command="{Binding DismissCommand}"
                        Style="{StaticResource CloseButtonStyle}"
                        VerticalAlignment="Top"/>

                <!-- Running spinner -->
                <ProgressBar DockPanel.Dock="Right"
                             IsIndeterminate="True"
                             Width="36" Height="4"
                             Foreground="#E63123"
                             VerticalAlignment="Center"
                             Margin="0,0,4,0"
                             Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}"/>

                <!-- Text stack -->
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding Title}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#333333"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding Message}"
                               FontSize="11"
                               Foreground="#666666"
                               TextWrapping="Wrap"
                               Margin="0,2,0,0"
                               Visibility="{Binding Message, Converter={StaticResource NullToVis}}"/>
                    <!-- Error detail link — walks up to Window.DataContext (MainViewModel) -->
                    <Button Content="Details im Status-Log"
                            Margin="0,4,0,0"
                            Style="{StaticResource DetailsLinkStyle}"
                            Visibility="{Binding ShowDetailsLink, Converter={StaticResource BoolToVis}}"
                            Command="{Binding DataContext.OpenProcessDetailCommand,
                                     RelativeSource={RelativeSource AncestorType=Window}}"/>
                </StackPanel>
            </DockPanel>
        </Grid>
    </Border>
</UserControl>
