<Window x:Class="Platee.Johann.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Platee.Johann.UI.ViewModels"
        xmlns:conv="clr-namespace:Platee.Johann.UI.Converters"
        mc:Ignorable="d"
        Title="Platé.Johann" Height="700" Width="1200"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Type badge colors -->
        <Style x:Key="TypeBadgeStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Background" Value="#E63123"/>
        </Style>
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#E63123"/>
            <Setter Property="Margin" Value="0,18,0,7"/>
        </Style>
        <Style x:Key="ContentTextStyle" TargetType="TextBox">
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="SortToggleStyle" TargetType="ToggleButton">
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Margin" Value="0,0,2,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:NullToVisibilityConverter x:Key="NullToVis"/>
        <conv:MarkdownFlowDocumentConverter x:Key="MdToDoc"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Loading overlay -->
        <Grid Grid.RowSpan="2" Panel.ZIndex="10"
              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <Rectangle Fill="#80FFFFFF"/>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Lade…" FontSize="16" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Row 0: Top bar -->
        <Grid Grid.Row="0" Background="#F0F0F0">
            <Border BorderThickness="0,0,0,1" BorderBrush="#E0E0E0">
                <DockPanel Margin="8,0">
                    <!-- Error / status message on the left -->
                    <TextBlock Text="{Binding ErrorMessage}" VerticalAlignment="Center"
                               Foreground="#C0392B" FontSize="12"
                               Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVis}}"/>
                    <!-- Right side: status indicator + settings -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right"
                                VerticalAlignment="Center" Margin="0,4">
                        <!-- Spinner (visible only while processing) -->
                        <ProgressBar IsIndeterminate="True" Width="100" Height="8" VerticalAlignment="Center"
                                     Margin="0,0,6,0" Foreground="#E63123"
                                     Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVis}}"/>
                        <Button x:Name="StatusTextButton"
                                Command="{Binding OpenProcessDetailCommand}"
                                ToolTip="{Binding StatusText}"
                                FontSize="14"
                                Background="Transparent" BorderThickness="0" Margin="0,0,8,0"
                                Cursor="Hand" Padding="4,0">
                            <TextBlock Text="🔔" FontSize="13"/>
                        </Button>
                        <Button Content="⚙ Einstellungen" Command="{Binding OpenSettingsCommand}"
                                ToolTip="Einstellungen öffnen"
                                Background="Transparent" BorderThickness="0"
                                FontSize="12" Padding="6,2" Cursor="Hand"/>
                    </StackPanel>
                    <!-- Process log popup (anchored to StatusTextButton) -->
                    <Popup x:Name="ProcessLogPopup"
                           IsOpen="{Binding IsProcessLogOpen, Mode=TwoWay}"
                           PlacementTarget="{Binding ElementName=StatusTextButton}"
                           Placement="Bottom"
                           StaysOpen="False"
                           AllowsTransparency="True"
                           PopupAnimation="Fade">
                        <Border Width="420" MaxHeight="320"
                                Background="White" BorderBrush="#CCCCCC" BorderThickness="1"
                                CornerRadius="4">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.15"/>
                            </Border.Effect>
                            <DockPanel Margin="0">
                                <!-- Header bar -->
                                <Border DockPanel.Dock="Top" Background="#F5F5F5" BorderThickness="0,0,0,1"
                                        BorderBrush="#E0E0E0" Padding="10,6">
                                    <DockPanel>
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                            <Button Content="Erledigte löschen" FontSize="10" Padding="6,2"
                                                    Cursor="Hand" Command="{Binding RemoveCompletedLogsCommand}"/>
                                            <Button Content="Alle löschen" FontSize="10" Padding="6,2" Margin="4,0,0,0"
                                                    Cursor="Hand" Command="{Binding ClearProcessLogCommand}"/>
                                        </StackPanel>
                                        <TextBlock Text="Status-Log" FontWeight="SemiBold" FontSize="12"
                                                   VerticalAlignment="Center"/>
                                    </DockPanel>
                                </Border>
                                <!-- Log items -->
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding ProcessLog}" Margin="0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="8,4,8,0" Padding="10,8"
                                                        BorderThickness="0,0,0,1" BorderBrush="#F0F0F0"
                                                        Background="White">
                                                    <DockPanel>
                                                        <!-- Time -->
                                                        <TextBlock DockPanel.Dock="Left" Text="{Binding DisplayTime}"
                                                                   FontSize="10" Foreground="#999"
                                                                   VerticalAlignment="Center" Margin="0,0,8,0" Width="44"/>
                                                        <!-- Right: spinner or result -->
                                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                                                    VerticalAlignment="Center">
                                                            <ProgressBar IsIndeterminate="True" Width="50" Height="4"
                                                                         Foreground="#E63123" VerticalAlignment="Center"
                                                                         Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}"/>
                                                            <TextBlock Text="{Binding ResultMessage}" FontSize="10"
                                                                       Foreground="#555" VerticalAlignment="Center"
                                                                       Visibility="{Binding IsRunning, Converter={StaticResource InverseBoolToVis}}"/>
                                                        </StackPanel>
                                                        <!-- Message -->
                                                        <TextBlock Text="{Binding Message}" FontSize="11"
                                                                   TextWrapping="Wrap" VerticalAlignment="Center"/>
                                                    </DockPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </DockPanel>
                        </Border>
                    </Popup>
                </DockPanel>
            </Border>
        </Grid>

        <!-- 3-pane layout -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160" MinWidth="120"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="280" MinWidth="200"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- === LEFT: Date list === -->
            <DockPanel Grid.Column="0" Background="#FAFAFA">
                <Border DockPanel.Dock="Top" Background="#E63123" Padding="12,10">
                    <TextBlock Text="Datum" Foreground="White" FontWeight="SemiBold"/>
                </Border>
                <Border DockPanel.Dock="Bottom" Padding="8,6" BorderThickness="0,1,0,0"
                        BorderBrush="#E0E0E0" Background="#F5F5F5">
                    <StackPanel>
                        <TextBlock Text="Abschnitte" FontSize="10" Foreground="#999" Margin="0,0,0,4"/>
                        <CheckBox Content="Ausführlich"    IsChecked="{Binding Sections.ShowProseSummary}"      FontSize="11" Margin="0,1"/>
                        <CheckBox Content="Zusammenfassung" IsChecked="{Binding Sections.ShowLongSummary}"     FontSize="11" Margin="0,1"/>
                        <CheckBox Content="Aufgaben"       IsChecked="{Binding Sections.ShowTaskList}"          FontSize="11" Margin="0,1"/>
                        <CheckBox Content="Gesprächsnotiz" IsChecked="{Binding Sections.ShowConversationNote}"  FontSize="11" Margin="0,1"/>
                        <CheckBox Content="E-Mail"         IsChecked="{Binding Sections.ShowEmailText}"         FontSize="11" Margin="0,1"/>
                        <CheckBox Content="Stundenzettel"  IsChecked="{Binding Sections.ShowStundenzettelText}" FontSize="11" Margin="0,1"/>
                        <CheckBox Content="Analog"         IsChecked="{Binding Sections.ShowAnalogText}"        FontSize="11" Margin="0,1"/>
                        <CheckBox Content="Transkript"     IsChecked="{Binding Sections.ShowTranscript}"         FontSize="11" Margin="0,1"/>
                    </StackPanel>
                </Border>
                <ListBox ItemsSource="{Binding AvailableDates}"
                         SelectedItem="{Binding SelectedDateItem}"
                         BorderThickness="0" Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayText}" Padding="12,6"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          Background="#E0E0E0"/>

            <!-- === CENTER: Entry list === -->
            <DockPanel Grid.Column="2" Background="White">
                <Border DockPanel.Dock="Top" Background="#E63123" Padding="12,10">
                    <TextBlock Text="{Binding SelectedDateDisplay}" Foreground="White" FontWeight="SemiBold"/>
                </Border>

                <!-- Sort / Filter toolbar -->
                <Border DockPanel.Dock="Top" Padding="6,4" BorderThickness="0,0,0,1"
                        BorderBrush="#E0E0E0" Background="#F9F9F9">
                    <DockPanel>
                        <CheckBox DockPanel.Dock="Right" Content="Nur unerledigte"
                                  IsChecked="{Binding ShowOnlyPending}"
                                  VerticalAlignment="Center" Margin="4,0,0,0" FontSize="11"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="↕" VerticalAlignment="Center" FontSize="11"
                                       Foreground="#666" Margin="0,0,4,0"/>
                            <ToggleButton Content="{Binding SortByIdLabel}"
                                          IsChecked="{Binding IsSortById, Mode=OneWay}"
                                          Command="{Binding SortByIdCommand}"
                                          Style="{StaticResource SortToggleStyle}"
                                          ToolTip="Nach Nummer sortieren"/>
                            <ToggleButton Content="{Binding SortByProjectLabel}"
                                          IsChecked="{Binding IsSortByProject, Mode=OneWay}"
                                          Command="{Binding SortByProjectCommand}"
                                          Style="{StaticResource SortToggleStyle}"
                                          ToolTip="Nach Projekt sortieren"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <Border DockPanel.Dock="Bottom" Padding="8" BorderThickness="0,1,0,0"
                        BorderBrush="#E0E0E0">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="+ Neues Element" Command="{Binding AddEntryCommand}"
                                Style="{StaticResource ActionButtonStyle}"
                                ToolTip="Neuen Eintrag anlegen"/>
                    </StackPanel>
                </Border>
                <ListBox x:Name="EntryListBox"
                         ItemsSource="{Binding Entries}"
                         SelectedItem="{Binding SelectedEntry}"
                         BorderThickness="0" Background="Transparent"
                         PreviewMouseLeftButtonDown="EntryListBox_PreviewMouseLeftButtonDown"
                         PreviewMouseMove="EntryListBox_PreviewMouseMove">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="4,2">
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Right" Text="✓" Foreground="#27AE60" FontSize="12"
                                               FontWeight="Bold" VerticalAlignment="Center" Margin="4,0,0,0"
                                               Visibility="{Binding IsDone, Converter={StaticResource BoolToVis}}"/>
                                    <TextBlock TextTrimming="CharacterEllipsis" FontSize="13">
                                        <Run Text="{Binding SequenceNumber, StringFormat='{}{0:D3}', Mode=OneWay}"
                                             FontStyle="Italic" Foreground="#AAAAAA"/>
                                        <Run Text=" "/>
                                        <Run Text="{Binding ProjectName, Mode=OneWay}"
                                             FontWeight="Bold" Foreground="#C0392B"/>
                                        <Run Text=" — "/>
                                        <Run Text="{Binding Title, Mode=OneWay}"/>
                                    </TextBlock>
                                </DockPanel>
                                <TextBlock Text="{Binding TypeBadge}" FontSize="10" Foreground="#888"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch"
                          Background="#E0E0E0"/>

            <!-- Toast notification overlay — top-right of main content area -->
            <Border Grid.Column="4" Panel.ZIndex="8"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,8,16,0" MaxWidth="320"
                    Background="White" BorderBrush="#CCCCCC" BorderThickness="1"
                    CornerRadius="6" Padding="12,8"
                    Cursor="Hand"
                    Visibility="{Binding IsToastVisible, Converter={StaticResource BoolToVis}}">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="2" BlurRadius="10" Opacity="0.2"/>
                </Border.Effect>
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding DismissToastCommand}"/>
                </Border.InputBindings>
                <DockPanel>
                    <ProgressBar DockPanel.Dock="Right" IsIndeterminate="True" Width="40" Height="4"
                                 Foreground="#E63123" VerticalAlignment="Center" Margin="8,0,0,0"
                                 Visibility="{Binding IsToastRunning, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Text="{Binding ToastMessage}" FontSize="12" TextWrapping="Wrap"
                               VerticalAlignment="Center" Foreground="#333"/>
                </DockPanel>
            </Border>

            <!-- === RIGHT: Detail view === -->
            <DockPanel Grid.Column="4" Background="White">
                <!-- Action toolbar -->
                <Border DockPanel.Dock="Bottom" Padding="8,6" BorderThickness="0,1,0,0"
                        BorderBrush="#E0E0E0">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0">
                            <Button Content="−" Command="{Binding Detail.ZoomOutCommand}"
                                    ToolTip="Verkleinern" Width="22" Height="22" Padding="0" FontSize="14" Cursor="Hand"/>
                            <TextBlock Text="{Binding Detail.ZoomText}" VerticalAlignment="Center"
                                       Margin="4,0" FontSize="11" MinWidth="40" TextAlignment="Center"/>
                            <Button Content="+" Command="{Binding Detail.ZoomInCommand}"
                                    ToolTip="Vergrößern" Width="22" Height="22" Padding="0" FontSize="14" Cursor="Hand"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="HTML"
                                    Command="{Binding Detail.GenerateHtmlCommand}"
                                    Style="{StaticResource ActionButtonStyle}"
                                    ToolTip="HTML-Datei erstellen und öffnen">
                                <Button.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="HTML in Zwischenablage kopieren"
                                                  Command="{Binding PlacementTarget.DataContext.Detail.CopyHtmlCommand,
                                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    </ContextMenu>
                                </Button.ContextMenu>
                            </Button>
                            <Button Content="PDF"
                                    Command="{Binding Detail.GeneratePdfCommand}"
                                    Style="{StaticResource ActionButtonStyle}"
                                    ToolTip="PDF-Datei erstellen und öffnen">
                                <Button.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="PDF in Zwischenablage kopieren"
                                                  Command="{Binding PlacementTarget.DataContext.Detail.CopyPdfCommand,
                                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    </ContextMenu>
                                </Button.ContextMenu>
                            </Button>
                            <Button Content="E-Mail"
                                    Command="{Binding Detail.CopyEmailCommand}"
                                    Style="{StaticResource ActionButtonStyle}"
                                    ToolTip="E-Mail-Text in Zwischenablage kopieren">
                                <Button.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="In Outlook öffnen"
                                                  Command="{Binding PlacementTarget.DataContext.Detail.OpenInOutlookCommand,
                                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    </ContextMenu>
                                </Button.ContextMenu>
                            </Button>
                            <Button Content="Kopieren"
                                    Command="{Binding Detail.CopyCommand}"
                                    Style="{StaticResource ActionButtonStyle}"
                                    ToolTip="Alle sichtbaren Sektionen in die Zwischenablage kopieren"/>
                            <Button Content="↻ Neu generieren"
                                    Command="{Binding Detail.ReprocessCommand}"
                                    Style="{StaticResource ActionButtonStyle}"
                                    ToolTip="GPT-Zusammenfassungen neu generieren">
                                <Button.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Ausführliche Zusammenfassung neu generieren"
                                                  Command="{Binding PlacementTarget.DataContext.Detail.ReprocessSectionCommand,
                                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="Ausführliche Zusammenfassung"/>
                                        <MenuItem Header="Zusammenfassung neu generieren"
                                                  Command="{Binding PlacementTarget.DataContext.Detail.ReprocessSectionCommand,
                                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="Zusammenfassung"/>
                                        <MenuItem Header="Aufgaben neu generieren"
                                                  Command="{Binding PlacementTarget.DataContext.Detail.ReprocessSectionCommand,
                                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="Aufgaben"/>
                                        <MenuItem Header="Gesprächsnotiz neu generieren"
                                                  Command="{Binding PlacementTarget.DataContext.Detail.ReprocessSectionCommand,
                                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="Gesprächsnotiz"/>
                                        <MenuItem Header="E-Mail neu generieren"
                                                  Command="{Binding PlacementTarget.DataContext.Detail.ReprocessSectionCommand,
                                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="E-Mail"/>
                                        <MenuItem Header="Stundenzettel neu generieren"
                                                  Command="{Binding PlacementTarget.DataContext.Detail.ReprocessSectionCommand,
                                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="Stundenzettel"/>
                                        <MenuItem Header="Analog neu generieren"
                                                  Command="{Binding PlacementTarget.DataContext.Detail.ReprocessSectionCommand,
                                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="Analog"/>
                                        <MenuItem Header="Transkript neu generieren"
                                                  Command="{Binding PlacementTarget.DataContext.Detail.ReprocessSectionCommand,
                                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="Transkript"/>
                                    </ContextMenu>
                                </Button.ContextMenu>
                            </Button>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Detail content — empty state -->
                <TextBlock Text="Eintrag auswählen" FontSize="16" Foreground="#AAA"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="{Binding Detail.HasNoEntry, Converter={StaticResource BoolToVis}}"/>

                <!-- Detail content — filled -->
                <ScrollViewer x:Name="DetailScrollViewer"
                              Padding="24,16" VerticalScrollBarVisibility="Auto"
                              PreviewMouseWheel="DetailScrollViewer_PreviewMouseWheel"
                              Visibility="{Binding Detail.HasEntry, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <StackPanel.LayoutTransform>
                            <ScaleTransform ScaleX="{Binding Detail.DetailZoom}"
                                            ScaleY="{Binding Detail.DetailZoom}"/>
                        </StackPanel.LayoutTransform>

                        <!-- Header: badge + project + title -->
                        <DockPanel Margin="0,0,0,4">
                            <Border Style="{StaticResource TypeBadgeStyle}" DockPanel.Dock="Left"
                                    Margin="0,0,8,0">
                                <TextBlock Text="{Binding Detail.DisplayTypeBadge}"
                                           Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                            </Border>
                            <TextBlock Text="{Binding Detail.DisplayProject}"
                                       FontSize="13" Foreground="#666" VerticalAlignment="Center"/>
                        </DockPanel>
                        <TextBlock Text="{Binding Detail.DisplayTitle}"
                                   FontSize="20" FontWeight="Bold" TextWrapping="Wrap"
                                   Margin="0,0,0,2"/>
                        <TextBlock FontSize="12" Foreground="#888" Margin="0,0,0,12">
                            <Run Text="{Binding Detail.DisplayDate, Mode=OneWay}"/>
                            <Run Text=" · "/>
                            <Run Text="{Binding Detail.DisplayDuration, Mode=OneWay}"/>
                        </TextBlock>

                        <Separator Margin="0,0,0,8"/>

                        <!-- Done status -->
                        <DockPanel Margin="0,0,0,12">
                            <Button DockPanel.Dock="Right"
                                    Content="{Binding Detail.IsDoneButtonText}"
                                    Command="{Binding Detail.ToggleDoneCommand}"
                                    Style="{StaticResource ActionButtonStyle}"
                                    FontSize="12"/>
                        </DockPanel>

                        <!-- Abstract — always shown when present, subtle highlight -->
                        <StackPanel Visibility="{Binding Detail.Entry.Abstract, Converter={StaticResource NullToVis}}"
                                    Margin="0,0,0,16">
                            <TextBlock Text="Abstract" Style="{StaticResource SectionHeaderStyle}"/>
                            <Border Background="#FFF5F4" BorderBrush="#FFDBD8" BorderThickness="0,0,0,2"
                                    CornerRadius="2" Padding="12,10">
                                <TextBox Text="{Binding Detail.DisplayAbstract, Mode=OneWay}"
                                         Style="{StaticResource ContentTextStyle}"/>
                            </Border>
                        </StackPanel>

                        <!-- Long Summary -->
                        <StackPanel Visibility="{Binding Detail.ShowLongSummarySection, Converter={StaticResource BoolToVis}}"
                                    Margin="0,0,0,16">
                            <TextBlock Text="Zusammenfassung" Style="{StaticResource SectionHeaderStyle}"/>
                            <FlowDocumentScrollViewer
                                Document="{Binding Detail.DisplayLongSummary, Converter={StaticResource MdToDoc}}"
                                VerticalScrollBarVisibility="Disabled"
                                HorizontalScrollBarVisibility="Disabled"
                                IsSelectionEnabled="True"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                FontFamily="Segoe UI, Arial"
                                FontSize="13"/>
                        </StackPanel>

                        <!-- Prose Summary -->
                        <StackPanel Visibility="{Binding Detail.ShowProseSummarySection, Converter={StaticResource BoolToVis}}"
                                    Margin="0,0,0,16">
                            <TextBlock Text="Ausführliche Zusammenfassung" Style="{StaticResource SectionHeaderStyle}"/>
                            <TextBox Text="{Binding Detail.DisplayProseSummary, Mode=OneWay}"
                                     Style="{StaticResource ContentTextStyle}"
                                     TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- Task list -->
                        <StackPanel Visibility="{Binding Detail.ShowTaskListSection, Converter={StaticResource BoolToVis}}"
                                    Margin="0,0,0,16">
                            <TextBlock Text="Aufgaben" Style="{StaticResource SectionHeaderStyle}"/>
                            <FlowDocumentScrollViewer
                                Document="{Binding Detail.DisplayTaskList, Converter={StaticResource MdToDoc}}"
                                VerticalScrollBarVisibility="Disabled"
                                HorizontalScrollBarVisibility="Disabled"
                                IsSelectionEnabled="True"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                FontFamily="Segoe UI, Arial"
                                FontSize="13"/>
                        </StackPanel>

                        <!-- Conversation note -->
                        <StackPanel Visibility="{Binding Detail.ShowConversationNoteSection, Converter={StaticResource BoolToVis}}"
                                    Margin="0,0,0,16">
                            <TextBlock Text="Gesprächsnotiz" Style="{StaticResource SectionHeaderStyle}"/>
                            <FlowDocumentScrollViewer
                                Document="{Binding Detail.DisplayConversationNote, Converter={StaticResource MdToDoc}}"
                                VerticalScrollBarVisibility="Disabled"
                                HorizontalScrollBarVisibility="Disabled"
                                IsSelectionEnabled="True"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                FontFamily="Segoe UI, Arial"
                                FontSize="13"/>
                        </StackPanel>

                        <!-- Stundenzettel -->
                        <StackPanel Visibility="{Binding Detail.ShowStundenzettelSection, Converter={StaticResource BoolToVis}}"
                                    Margin="0,0,0,16">
                            <TextBlock Text="Stundenzettel" Style="{StaticResource SectionHeaderStyle}"/>
                            <FlowDocumentScrollViewer
                                Document="{Binding Detail.DisplayStundenzettelText, Converter={StaticResource MdToDoc}}"
                                VerticalScrollBarVisibility="Disabled"
                                HorizontalScrollBarVisibility="Disabled"
                                IsSelectionEnabled="True"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                FontFamily="Segoe UI, Arial"
                                FontSize="13"/>
                        </StackPanel>

                        <!-- Analog -->
                        <StackPanel Visibility="{Binding Detail.ShowAnalogSection, Converter={StaticResource BoolToVis}}"
                                    Margin="0,0,0,16">
                            <TextBlock Text="Analog" Style="{StaticResource SectionHeaderStyle}"/>
                            <FlowDocumentScrollViewer
                                Document="{Binding Detail.DisplayAnalogText, Converter={StaticResource MdToDoc}}"
                                VerticalScrollBarVisibility="Disabled"
                                HorizontalScrollBarVisibility="Disabled"
                                IsSelectionEnabled="True"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                FontFamily="Segoe UI, Arial"
                                FontSize="13"/>
                        </StackPanel>

                        <!-- E-Mail Text -->
                        <StackPanel Visibility="{Binding Detail.ShowEmailSection, Converter={StaticResource BoolToVis}}"
                                    Margin="0,0,0,16">
                            <TextBlock Text="E-Mail" Style="{StaticResource SectionHeaderStyle}"/>
                            <FlowDocumentScrollViewer
                                Document="{Binding Detail.DisplayEmailText, Converter={StaticResource MdToDoc}}"
                                VerticalScrollBarVisibility="Disabled"
                                HorizontalScrollBarVisibility="Disabled"
                                IsSelectionEnabled="True"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                FontFamily="Segoe UI, Arial"
                                FontSize="13"/>
                        </StackPanel>

                        <!-- Transcript -->
                        <StackPanel Visibility="{Binding Detail.ShowTranscriptSection, Converter={StaticResource BoolToVis}}"
                                    Margin="0,0,0,16">
                            <TextBlock Text="Transkript" Style="{StaticResource SectionHeaderStyle}"/>
                            <TextBox Text="{Binding Detail.DisplayTranscript, Mode=OneWay}"
                                     Style="{StaticResource ContentTextStyle}"
                                     TextWrapping="Wrap" Foreground="#555"/>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Grid>

    </Grid>
</Window>
